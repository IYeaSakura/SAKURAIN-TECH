{
  "colors": {
    "primary": "#569CD6",
    "primaryHover": "#4A8BC2",
    "surface": "#0D0D0D",
    "background": "#000000",
    "text": "#FFFFFF",
    "textMuted": "#808080",
    "textSubtle": "#6E6E6E",
    "accent": "#4EC9B0",
    "border": "rgba(255,255,255,0.12)",
    "borderHover": "rgba(255,255,255,0.2)",
    "success": "#4EC9B0",
    "warning": "#B5CEA8"
  },
  "typography": {
    "fontFamily": "'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif",
    "heroSize": "56px",
    "h1": "40px",
    "h2": "32px",
    "h3": "24px",
    "body": "16px",
    "small": "14px",
    "lineHeightTight": 1.2,
    "lineHeightNormal": 1.6
  },
  "spacing": {
    "section": "128px",
    "container": "1280px",
    "gridGap": "24px",
    "cardPadding": "40px"
  },
  "animation": {
    "duration": {
      "fast": 0.3,
      "normal": 0.6,
      "slow": 1.0,
      "stagger": 0.08
    },
    "easing": {
      "smooth": [0.16, 1, 0.3, 1],
      "bounce": [0.34, 1.56, 0.64, 1],
      "spring": { "stiffness": 100, "damping": 15 }
    },
    "parallax": {
      "backgroundSpeed": 0.2,
      "contentSpeed": 1,
      "floatSpeed": 1.2
    }
  },
  "effects": {
    "glassBg": "rgba(13,13,13,0.8)",
    "glassBlur": "12px",
    "shadowSm": "0 1px 2px rgba(0,0,0,0.3)",
    "shadowMd": "0 4px 6px -1px rgba(0,0,0,0.4)",
    "shadowLg": "0 20px 25px -5px rgba(0,0,0,0.5)",
    "shadowHover": "0 25px 50px -12px rgba(86,156,214,0.25)"
  }
}
