{
  "colors": {
    "primary": "#2563eb",
    "primaryHover": "#1d4ed8",
    "surface": "#ffffff",
    "background": "#fafafa",
    "text": "#111827",
    "textMuted": "#6b7280",
    "textSubtle": "#9ca3af",
    "accent": "#0ea5e9",
    "border": "rgba(0,0,0,0.08)",
    "borderHover": "rgba(0,0,0,0.15)",
    "success": "#10b981",
    "warning": "#f59e0b"
  },
  "typography": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
    "heroSize": "56px",
    "h1": "40px",
    "h2": "32px",
    "h3": "24px",
    "body": "16px",
    "small": "14px",
    "lineHeightTight": 1.2,
    "lineHeightNormal": 1.6
  },
  "spacing": {
    "section": "128px",
    "container": "1280px",
    "gridGap": "24px",
    "cardPadding": "40px"
  },
  "animation": {
    "duration": {
      "fast": 0.3,
      "normal": 0.6,
      "slow": 1.0,
      "stagger": 0.08
    },
    "easing": {
      "smooth": [0.16, 1, 0.3, 1],
      "bounce": [0.34, 1.56, 0.64, 1],
      "spring": { "stiffness": 100, "damping": 15 }
    },
    "parallax": {
      "backgroundSpeed": 0.2,
      "contentSpeed": 1,
      "floatSpeed": 1.2
    }
  },
  "effects": {
    "glassBg": "rgba(255,255,255,0.8)",
    "glassBlur": "12px",
    "shadowSm": "0 1px 2px rgba(0,0,0,0.05)",
    "shadowMd": "0 4px 6px -1px rgba(0,0,0,0.1)",
    "shadowLg": "0 20px 25px -5px rgba(0,0,0,0.1)",
    "shadowHover": "0 25px 50px -12px rgba(0,0,0,0.25)"
  }
}
