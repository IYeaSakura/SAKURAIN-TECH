{
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/image/logo.webp"
    },
    {
      "source": "/favicon",
      "destination": "/image/logo.webp"
    },
    {
      "source": "/feed/atom",
      "destination": "/atom.xml"
    },
    {
      "source": "/feed/json",
      "destination": "/feed.json"
    },
    {
      "source": "/feed",
      "destination": "/feed.xml"
    },
    {
      "source": "/docs",
      "destination": "/index.html"
    },
    {
      "source": "/docs/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/friends",
      "destination": "/index.html"
    },
    {
      "source": "/friends/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/blog",
      "destination": "/index.html"
    },
    {
      "source": "/blog/:path*",
      "destination": "/index.html"
    }
  ]
}
