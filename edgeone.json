{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "nodeVersion": "20.18.0",
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/image/logo.webp"
    },
    {
      "source": "/favicon",
      "destination": "/image/logo.webp"
    },
    {
      "source": "/feed/atom",
      "destination": "/atom.xml"
    },
    {
      "source": "/feed/json",
      "destination": "/feed.json"
    },
    {
      "source": "/feed",
      "destination": "/feed.xml"
    }
  ],
  "caches": [
    {
      "source": "/assets/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/*.js",
      "cacheTtl": 86400
    },
    {
      "source": "/*.css",
      "cacheTtl": 86400
    },
    {
      "source": "/image/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/data/*",
      "cacheTtl": 3600
    },
    {
      "source": "/feed.xml",
      "cacheTtl": 3600
    },
    {
      "source": "/atom.xml",
      "cacheTtl": 3600
    },
    {
      "source": "/feed.json",
      "cacheTtl": 3600
    },
    {
      "source": "/404.html",
      "cacheTtl": 0
    },
    {
      "source": "/index.html",
      "cacheTtl": 0
    }
  ],
  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/image/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/feed.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/rss+xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/atom.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/atom+xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/feed.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/feed+json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/404.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
