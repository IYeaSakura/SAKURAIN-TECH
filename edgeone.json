{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "nodeVersion": "20.18.0",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "source": "/feed",
      "destination": "/feed.xml",
      "statusCode": 200
    },
    {
      "source": "/feed/atom",
      "destination": "/atom.xml",
      "statusCode": 200
    },
    {
      "source": "/feed/json",
      "destination": "/feed.json",
      "statusCode": 200
    },
    {
      "source": "/(.*)",
      "destination": "/index.html",
      "statusCode": 200
    }
  ],
  "caches": [
    {
      "source": "/assets/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/*.js",
      "cacheTtl": 86400
    },
    {
      "source": "/*.css",
      "cacheTtl": 86400
    },
    {
      "source": "/image/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/data/*",
      "cacheTtl": 3600
    },
    {
      "source": "/404.html",
      "cacheTtl": 0
    },
    {
      "source": "/index.html",
      "cacheTtl": 0
    }
  ],
  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/image/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/404.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
